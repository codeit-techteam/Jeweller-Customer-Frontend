# Backend URL for release/preview builds. In local dev, the app uses Metro’s LAN host + port 5105 automatically.
# Allowed forms: http://192.168.x.x:5105 or http://192.168.x.x:5105/api (use your Mac’s current LAN IP, not localhost).
EXPO_PUBLIC_API_URL=http://192.168.29.30:5105/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_DEV_AUTH=false

# EAS preview/production: set the same keys in eas.json (build.env) or Expo dashboard → Environment variables.
