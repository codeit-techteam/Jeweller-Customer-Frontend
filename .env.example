# Use your Mac’s LAN IP so physical devices/emulators can reach the backend (not localhost).
# Allowed forms: http://192.168.x.x:5105 or http://192.168.x.x:5105/api
EXPO_PUBLIC_API_URL=http://192.168.0.103:5105/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_DEV_AUTH=false

# EAS preview/production: set the same keys in eas.json (build.env) or Expo dashboard → Environment variables.
